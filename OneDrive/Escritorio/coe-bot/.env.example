# ─────────────────────────────────────────────────────
# COE Bot — Variables de Entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a GitHub
# ─────────────────────────────────────────────────────

# Puerto del servidor (default: 3000)
PORT=3000

# Token de verificación del Webhook (invéntalo tú, debe coincidir con el que registres en Meta)
VERIFY_TOKEN=coe_webhook_2024

# ── Anthropic ──────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── WhatsApp Business API ──────────────────────────
# Consola Meta: https://developers.facebook.com
# App > WhatsApp > Configuración de API
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_ID=1234567890123456

# ── Facebook Messenger ─────────────────────────────
# App > Messenger > Configuración de API > Token de acceso a la página
PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Instagram ──────────────────────────────────────
# App > Instagram > Configuración > Token de acceso
# (puede ser el mismo PAGE_ACCESS_TOKEN si es la misma app)
INSTAGRAM_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxx
